# Copy to .env and fill in your values. The app reads this at launch;
# values set in the in-app settings panel override these.

# LLM chat API (OpenAI-compatible endpoint)
LLM_API_URL=http://localhost:8317/v1
LLM_API_KEY=your-llm-api-key
LLM_MODEL=claude-sonnet-4-6

# Semantic Scholar API key (citation resolution) — https://www.semanticscholar.org/product/api
S2_API_KEY=s2k-your-key-here
